rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helper Functions ---
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    
    function isFaculty() {
      return isAuthenticated() && exists(/databases/$(database)/documents/faculty/$(request.auth.uid));
    }
    
    function isStudent() {
      return isAuthenticated() && exists(/databases/$(database)/documents/students/$(request.auth.uid));
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // --- Collection Rules ---

    // 1. Admins Collection
    match /admins/{userId} {
      allow read: if isAdmin() || isOwner(userId);
      allow write: if isAdmin();
    }

    // 2. Faculty Collection
    match /faculty/{userId} {
      allow read: if isAuthenticated(); // Anyone logged in can see faculty (for dropdowns, lists)
      allow write: if isAdmin() || isOwner(userId);
    }

    // 3. Students Collection
    match /students/{userId} {
      // Temporarily open entirely so aggressive browser caches running old JS don't crash the demo
      allow read, write: if true;
    }

    // 4. Courses Collection
    match /courses/{courseId} {
      allow read: if isAuthenticated(); // All logged-in users can browse courses
      allow create, delete: if isAdmin(); // Only admins can add/delete courses
      // Admins can update anything; students can only update availableSeats (for enrollment/drop)
      allow update: if isAdmin() || (isStudent() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['availableSeats']));
    }

    // 5. Enrollments Collection
    match /enrollments/{enrollmentId} {
      allow read: if isAuthenticated(); 
      // Students can enroll themselves; Admins can enroll anyone
      allow create: if isAdmin() || (isStudent() && request.resource.data.studentId == request.auth.uid);
      // Students can drop (delete/update) their own courses; Admins can do anything
      allow update, delete: if isAdmin() || (isStudent() && resource.data.studentId == request.auth.uid);
    }

    // 6. Results/Grades Collection
    match /results/{resultId} {
      // Students can only see their own results. Admins and Faculty can see all results.
      allow read: if isAdmin() || isFaculty() || (isStudent() && resource.data.studentId == request.auth.uid);
      // Only Faculty and Admins can post/edit grades
      allow write: if isAdmin() || isFaculty();
    }

  }
}
